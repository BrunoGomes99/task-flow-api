# Copie para .env e ajuste (o ficheiro .env não deve ser versionado).
# Docker Compose carrega variáveis de .env automaticamente.

# Credenciais do MongoDB (root). A API e o mongo-express usam o mesmo par.
MONGO_ROOT_USERNAME=root
MONGO_ROOT_PASSWORD=example

# Portas no host para a API (altere se 8080/8081 já estiverem em uso).
API_HTTP_HOST_PORT=8080
API_HTTPS_HOST_PORT=8081

# Porta no host para o mongo-express (evita conflito com HTTPS da API em 8081).
MONGO_EXPRESS_HOST_PORT=8082

# Credenciais Basic Auth do mongo-express (UI).
MONGO_EXPRESS_USER=mongoexpressuser
MONGO_EXPRESS_PASSWORD=mongoexpresspass

# Opcional: prefixo de registo de imagens (CI).
# DOCKER_REGISTRY=
