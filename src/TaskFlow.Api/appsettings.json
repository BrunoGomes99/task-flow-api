{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "MongoDb": {
    "ConnectionString": "mongodb://localhost:27017",
    "DatabaseName": "TaskFlowDb",
    "UsersCollectionName": "Users",
    "TasksCollectionName": "Tasks"
  },
  "PasswordHashing": {
    "WorkFactor": 12
  },
  "Jwt": {
    "Secret": "TaskFlow_DevOnly_ChangeInProduction_Min32Chars!",
    "Issuer": "TaskFlow",
    "Audience": "TaskFlow.Api",
    "AccessTokenLifetimeSeconds": 3600
  },
  "AllowedHosts": "*"
}
